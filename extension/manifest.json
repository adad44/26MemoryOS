{
  "manifest_version": 3,
  "name": "MemoryOS Capture",
  "version": "0.1.0",
  "description": "Captures page title, URL, and visible text for the local MemoryOS index.",
  "permissions": ["tabs"],
  "host_permissions": ["http://127.0.0.1:8765/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
